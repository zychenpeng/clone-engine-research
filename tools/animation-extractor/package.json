{
  "name": "@clone-engine/animation-extractor",
  "version": "0.1.0",
  "private": true,
  "description": "2-layer animation extractor (DOM getAnimations + Claude Vision) producing canonical animation-spec.json",
  "type": "module",
  "main": "./schema.ts",
  "exports": {
    "./schema": "./schema.ts"
  },
  "bin": {
    "animation-extract": "./cli.mjs"
  },
  "scripts": {
    "extract:dom": "tsx extract-dom.mjs",
    "extract:rrweb": "tsx extract-rrweb.mjs",
    "extract:vision": "tsx extract-vision.mjs",
    "cross-validate": "tsx cross-validate.mjs",
    "merge": "tsx merge.mjs",
    "cli": "node cli.mjs",
    "test": "tsx --test test/schema.test.mjs test/merge.test.mjs test/vision.test.mjs test/rrweb.test.mjs test/cross-validate.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rrweb": "^2.0.0-alpha.4"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
